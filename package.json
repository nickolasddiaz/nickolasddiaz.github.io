{
	"name": "nickolasddiaz-portfolio",
	"private": false,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"predeploy": "npm run build",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "bun run test:unit -- --run",
		"deploy": "npm run build && npx gh-pages -d build --dotfiles"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/marked": "^6.0.0",
		"@types/node": "^25.5.0",
		"@vitest/browser-playwright": "^4.0.15",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"flowbite": "^4.0.1",
		"flowbite-svelte": "^1.31.0",
		"flowbite-svelte-blocks": "^2.1.0",
		"flowbite-svelte-icons": "^3.1.0",
		"flowbite-typography": "^1.0.5",
		"gh-pages": "^6.3.0",
		"globals": "^17.4.0",
		"playwright": "^1.57.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"serve": "^14.2.5",
		"shiki": "^4.0.2",
		"super-sitemap": "^1.0.7",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"svelte-youtube-embed": "^0.4.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.48.1",
		"vite": "^8.0.3",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.15",
		"vitest-browser-svelte": "^2.0.1"
	},
	"dependencies": {
		"@sveltejs/adapter-static": "^3.0.10",
		"flexsearch": "^0.8.212"
	}
}
